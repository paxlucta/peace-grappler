# ClipBuilder environment template.
# Copy to .env and fill in only the keys you want active.
# .env is auto-loaded on app start (see src/app.py:_load_dotenv).

# ── AI task providers (analysis / wizard / captions) ────────────────────────
# Three of the four providers use locally-installed CLIs that handle auth
# themselves — no env vars needed once you've signed in to each CLI:
#   • Claude Code   →  run `claude` once in Terminal
#   • Gemini CLI    →  run `gemini` once (or set GEMINI_API_KEY below)
#   • Codex CLI     →  run `codex login` once
#
# MiniMax has no CLI; it's HTTPS-API-only, so this key is the *only* way
# to enable it on /settings.
MINIMAX_API_KEY=

# ── Transcription providers ─────────────────────────────────────────────────
# Local Whisper (the default) needs no key — faster-whisper downloads the
# model on first use. The cloud options below are opt-in:
#
# OpenAI hosted Whisper (whisper-1):
OPENAI_API_KEY=

# Google Gemini audio transcription (also re-used by the Gemini CLI when
# you'd rather skip the interactive sign-in flow):
GEMINI_API_KEY=
# Optional alias — Google's own SDKs read GOOGLE_API_KEY too.
# GOOGLE_API_KEY=
